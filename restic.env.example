# Restic environment template for macOS backups.
# Copy to 'restic.env', edit, and keep it chmod 600.
# Keep the repository URL itself in restic-repository.txt so the rest-server
# password does not need to live in this file.
# See Docs/RESTIC_ENV.md for detailed options and examples.
# bootstrap.sh replaces {{HOSTNAME}} with your system ComputerName.
export RESTIC_HOST="{{HOSTNAME}}"

# Password (recommended):
# Use setup_password.sh to store a generated password in Keychain and update
# RESTIC_PASSWORD_COMMAND in this file.
# Manual plaintext passwords are documented in Docs/RESTIC_ENV.md.
export RESTIC_PASSWORD_COMMAND='security find-generic-password -a restic-rest-client-macbook -s restic-rest-client-macbook -w'

# Repository location (recommended default):
# Keep the REST URL in restic-repository.txt. The tracked template matches the
# default --private-repos layout from the companion restic-rest-server repo.
export RESTIC_REPOSITORY_FILE="{{SCRIPT_DIR}}/restic-repository.txt"
# Optional inline alternative if you intentionally do not use the repository file:
# export RESTIC_REPOSITORY="rest:https://backup:REPLACE_WITH_SERVER_PASSWORD@backup.example.com/backup/{{HOSTNAME}}"

# Wait for an active restic lock instead of failing immediately.
export RESTIC_RETRY_LOCK="10m"

# Client-side prune is disabled by default because the companion
# restic-rest-server repo defaults to --append-only. Set this to true only if
# the server has been switched to client-managed maintenance mode.
export RESTIC_PRUNE_ENABLED="false"

# Prune policy (optional overrides)
export RESTIC_KEEP_DAILY="7"
export RESTIC_KEEP_WEEKLY="4"
export RESTIC_KEEP_MONTHLY="6"

# Remove per-run logs older than this many days (used by run_backup.sh logcleanup).
export RESTIC_LOG_RETENTION_DAYS="14"

# Optional laptop safety guards. Recommended on notebooks to avoid sleep/network
# interruptions and stale restic locks.
# export RESTIC_BACKUP_REQUIRE_AC_POWER="true"
# export RESTIC_BACKUP_SKIP_WHEN_CLAMSHELL_CLOSED="false"
# export RESTIC_PRUNE_REQUIRE_AC_POWER="true"
# export RESTIC_PRUNE_SKIP_WHEN_CLAMSHELL_CLOSED="false"

# - Leave unused options commented out.
# - Never commit a populated 'restic.env'.
# - If you rotate credentials, update the keychain or env var accordingly.

# Optional: email notifications (multipart text+HTML with attached log via msmtp)
# export RESTIC_NOTIFY_EMAIL="you@example.com"
# export RESTIC_NOTIFY_SUBJECT_PREFIX="[restic]"  # optional subject prefix
# # If your msmtp binary is non-standard:
# # export MSMTP_BIN="/opt/homebrew/bin/msmtp"
# # Toggle notifications:
# # export RESTIC_NOTIFY_ON_FAILURE="true"
# # export RESTIC_NOTIFY_ON_SUCCESS="false"  # backup/prune success emails, set true only when testing
# # Test the notification path without touching the repository:
# # ./run_backup.sh test-email                # generic notification path
# # ./run_backup.sh test-success-email        # success template
# # ./run_backup.sh test-failure-email        # generic non-lock failure (exit 1)
# # ./run_backup.sh test-warning-email        # backup warning / partial snapshot (exit 3)
# # ./run_backup.sh test-lock-failure-email   # repository lock failure (exit 11)
