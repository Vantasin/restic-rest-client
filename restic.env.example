# Restic environment template for macOS backups.
# Copy to 'restic.env', edit the server-specific placeholders, and keep it
# chmod 600.
# Default flow: keep the repository URL, REST username, and Keychain-backed
# password commands in this file.
# See Docs/RESTIC_ENV.md for detailed options and examples.
# bootstrap.sh prepopulates RESTIC_HOST with your system ComputerName and
# RESTIC_REPOSITORY_NAME with a URL-safe default repo name.
export RESTIC_HOST="{{HOSTNAME}}"

# REST server access:
# The server admin should provide the per-user base HTTPS URL, username, and
# password without inline credentials in the URL. Choose a repository name
# below that base path. Run `make configure` to populate these values, then
# `make init-repo` to create the repository.
export RESTIC_REPOSITORY_BASE_URL="https://REPLACE_WITH_SERVER_HOST/REPLACE_WITH_USER_PATH_PREFIX"
export RESTIC_REPOSITORY_NAME="{{HOSTNAME_SLUG}}"
export RESTIC_REPOSITORY="rest:${RESTIC_REPOSITORY_BASE_URL%/}/${RESTIC_REPOSITORY_NAME}"
export RESTIC_REST_USERNAME="REPLACE_WITH_SERVER_USERNAME"
export RESTIC_REST_PASSWORD="$(security find-generic-password -a restic-rest-client-rest-server -s restic-rest-client-rest-server -w)"

# Repository password (recommended):
# After you store the admin-provided REST password, use setup_password.sh
# --repository to generate the repository password locally in Keychain. Then
# run `make init-repo` to create the repository.
export RESTIC_PASSWORD_COMMAND="security find-generic-password -a restic-rest-client-repository -s restic-rest-client-repository -w"

# Wait for an active restic lock instead of failing immediately.
export RESTIC_RETRY_LOCK="10m"

# Client-side prune is disabled by default because the companion
# restic-rest-server repo defaults to --append-only. Set this to true only if
# the server has been switched to client-managed maintenance mode.
export RESTIC_PRUNE_ENABLED="false"

# Prune policy (optional overrides)
export RESTIC_KEEP_DAILY="7"
export RESTIC_KEEP_WEEKLY="4"
export RESTIC_KEEP_MONTHLY="6"

# Remove per-run logs older than this many days (used by run_backup.sh logcleanup).
export RESTIC_LOG_RETENTION_DAYS="14"

# Optional laptop safety guards. Recommended on notebooks to avoid sleep/network
# interruptions and stale restic locks.
# export RESTIC_BACKUP_REQUIRE_AC_POWER="true"
# export RESTIC_BACKUP_SKIP_WHEN_CLAMSHELL_CLOSED="false"
# export RESTIC_PRUNE_REQUIRE_AC_POWER="true"
# export RESTIC_PRUNE_SKIP_WHEN_CLAMSHELL_CLOSED="false"

# - Leave unused options commented out.
# - Never commit a populated 'restic.env'.
# - If you rotate credentials, update the matching Keychain entry or env var.

# Optional: email notifications (multipart text+HTML with attached log via msmtp)
# export RESTIC_NOTIFY_EMAIL="you@example.com"
# export RESTIC_NOTIFY_SUBJECT_PREFIX="[restic]"
# export MSMTP_BIN="/opt/homebrew/bin/msmtp"
# export RESTIC_NOTIFY_ON_FAILURE="true"
# export RESTIC_NOTIFY_ON_SUCCESS="false"
