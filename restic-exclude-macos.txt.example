{{HOME}}/Library/Application\ Support/com.apple.TCC
{{HOME}}/Library/Application\ Support/com.apple.avfoundation/Frecents
{{HOME}}/Library/Application\ Support/com.apple.sharedfilelist
{{HOME}}/Library/Assistant/SiriVocabulary
{{HOME}}/Library/Autosave\ Information
{{HOME}}/Library/ContainerManager
{{HOME}}/Library/Containers/*/.com.apple.containermanagerd.metadata.plist
{{HOME}}/Library/Containers/*/Data
{{HOME}}/Library/Containers/com.apple.archiveutility
{{HOME}}/Library/Containers/com.apple.Home
{{HOME}}/Library/Containers/com.apple.Maps/Data/Maps
{{HOME}}/Library/Containers/com.apple.MobileSMS
{{HOME}}/Library/Containers/com.apple.Notes
{{HOME}}/Library/Containers/com.apple.Safari
{{HOME}}/Library/Containers/com.apple.Safari.WebApp
{{HOME}}/Library/Containers/com.apple.VoiceMemos
{{HOME}}/Library/Containers/com.apple.corerecents.recentsd/Data/Library/Recents
{{HOME}}/Library/Containers/com.apple.mail
{{HOME}}/Library/Containers/com.apple.news
{{HOME}}/Library/Containers/com.apple.stocks
{{HOME}}/Library/Cookies
{{HOME}}/Library/CoreFollowUp
{{HOME}}/Library/DoNotDisturb
{{HOME}}/Library/HomeKit
{{HOME}}/Library/IdentityServices
{{HOME}}/Library/IntelligencePlatform
{{HOME}}/Library/Mail
{{HOME}}/Library/Messages
{{HOME}}/Library/PersonalizationPortrait
{{HOME}}/Library/Preferences/com.apple.AddressBook.plist
{{HOME}}/Library/Preferences/com.apple.MobileSMS.CKDNDList.plist
{{HOME}}/Library/Preferences/com.apple.MobileSMS.plist
{{HOME}}/Library/Preferences/com.apple.homed.notbackedup.plist
{{HOME}}/Library/Preferences/com.apple.homed.plist
{{HOME}}/Library/Preferences/com.apple.madrid.plist
{{HOME}}/Library/Preferences/com.apple.mail-shared.plist
{{HOME}}/Library/Preferences/com.apple.messages.pinning.plist
{{HOME}}/Library/Safari
{{HOME}}/Library/Sharing
{{HOME}}/Library/Shortcuts
{{HOME}}/Library/StatusKit
{{HOME}}/Library/Suggestions
{{HOME}}/Library/Trial
{{HOME}}/Library/Weather
{{HOME}}/Library/com.apple.aiml.instrumentation
{{HOME}}/Library/com.apple.bluetooth.services.cloud/CachedRecords/SoundProfileAsset

# ---------------------------
# 8. Applications (usually not included anyway)
# ---------------------------
# Your include file does NOT include /Applications,
# so these are redundant but left here as documentation.
# /Applications

# ---------------------------
# 9. System items we never want (for safety)
# ---------------------------
/System
/private/var/vm
/Volumes
